<div class="max-w-md mx-auto px-6 py-24 text-center space-y-6 font-sans">
  
  <span class="text-[10px] tracking-[0.4em] uppercase font-bold text-brandAccent block">
    Error 404
  </span>
  
  <h1 class="text-3xl md:text-5xl font-light tracking-tight text-neutral-900 font-serif">
    Page Not Found
  </h1>
  
  <div class="w-12 h-[2px] mx-auto bg-brandAccent"></div>
  
  <p class="text-xs md:text-sm text-neutral-500 font-light leading-relaxed">
    The page you are looking for does not exist or has been relocated within our roasting parameters.
  </p>
  
  <div class="pt-4">
    <a href="/" class="px-8 py-3.5 bg-brandPrimary text-white text-xs font-bold uppercase tracking-widest hover:bg-neutral-800 transition-colors inline-block rounded-none">
      Back to Home
    </a>
  </div>

</div>

{% schema %}
{
  "name": "404 Page",
  "settings": []
}
{% endschema %}
