<div class="max-w-7xl mx-auto px-4 md:px-6 py-8 md:py-16 space-y-16 font-sans">
  
  <!-- Breadcrumb and back link -->
  <div class="flex items-center justify-between border-b border-neutral-100 pb-4">
    <a href="/collections/all" class="flex items-center gap-2 text-xs uppercase tracking-widest text-neutral-500 hover:text-neutral-950 transition-colors font-bold group">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 group-hover:-translate-x-0.5 transition-transform"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      <span>Back to offerings</span>
    </a>
    <div class="hidden sm:flex items-center gap-3 text-[10px] uppercase tracking-widest font-semibold text-neutral-400">
      <span>Shop</span>
      <span>/</span>
      <span class="text-neutral-900 font-bold">{{ product.title }}</span>
    </div>
  </div>

  <!-- Main product columns -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
    
    <!-- Left Visual Column -->
    <div class="lg:col-span-7 space-y-6">
      <div class="relative aspect-square bg-stone-50 border border-neutral-100 overflow-hidden">
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 1000 }}"
            alt="{{ product.title | escape }}"
            class="w-full h-full object-cover"
            id="ProductMainImage"
          >
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'w-full h-full' }}
        {% endif %}
        
        <!-- Processing Badges -->
        <div class="absolute top-4 left-4 flex flex-col gap-2">
          <span class="bg-brandPrimary/90 text-[10px] text-white uppercase font-bold tracking-widest px-3 py-1">
            {{ product.metafields.custom.process | default: "Anaerobic Thermal Shock" }}
          </span>
        </div>
      </div>

      <!-- Quick specs grid -->
      <div class="p-4 bg-brandCardBg border border-purple-100 grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        <div>
          <span class="text-[10px] text-neutral-400 block font-bold uppercase tracking-wider">Variety</span>
          <span class="text-xs font-semibold text-neutral-800">{{ product.metafields.custom.variety | default: "Gesha / Bourbon" }}</span>
        </div>
        <div>
          <span class="text-[10px] text-neutral-400 block font-bold uppercase tracking-wider">Elevation</span>
          <span class="text-xs font-semibold text-neutral-800">{{ product.metafields.custom.elevation | default: "1,930m" }}</span>
        </div>
        <div>
          <span class="text-[10px] text-neutral-400 block font-bold uppercase tracking-wider">Producer</span>
          <span class="text-xs font-semibold text-neutral-800 truncate block max-w-[120px] mx-auto">{{ product.metafields.custom.producer | default: "Diego Bermudez" }}</span>
        </div>
        <div>
          <span class="text-[10px] text-neutral-400 block font-bold uppercase tracking-wider">Origin</span>
          <span class="text-xs font-semibold text-neutral-800 truncate block max-w-[120px] mx-auto">{{ product.metafields.custom.origin | default: "Colombia, Cauca" | split: ',' | first }}</span>
        </div>
      </div>
    </div>

    <!-- Right Details Column -->
    <div class="lg:col-span-5 space-y-8 lg:sticky lg:top-28">
      
      <div class="space-y-2">
        <span class="text-[10px] tracking-[0.3em] uppercase font-bold block text-brandAccent">
          Single-Origin Micro-Lot
        </span>
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-normal text-neutral-900 tracking-tight font-serif">
          {{ product.title }}
        </h1>
        <p class="text-xs md:text-sm text-neutral-500 font-light leading-relaxed">
          {{ product.metafields.custom.subtitle | default: "Colombian micro-lot highlighting volcanic elevations and exquisite yeast ferment." }}
        </p>
        <div class="pt-2 text-2xl font-semibold text-neutral-900 font-mono text-brandAccent">
          {{ product.price | money }}
        </div>
      </div>

      <hr class="border-neutral-100">

      <div class="text-xs md:text-sm text-neutral-600 leading-relaxed font-light text-brandText">
        {{ product.description }}
      </div>

      <!-- Flavor Notes bubbles -->
      <div class="space-y-2">
        <span class="text-[10px] text-neutral-400 block font-bold uppercase tracking-wider">
          Tasting Profile Indicator
        </span>
        <div class="flex flex-wrap gap-1.5">
          {% assign notes = product.metafields.custom.tasting_notes | default: "Lychee Fruit, Pink Raspberry, Passionfruit, White Chocolate" | split: ',' %}
          {% for note in notes %}
            <span class="text-xs bg-white border border-brandAccent text-brandPrimary px-3 py-1.5 font-mono tracking-tight font-semibold">
              {{ note | strip }}
            </span>
          {% endfor %}
        </div>
      </div>

      <!-- Add to Cart Form -->
      {% form 'product', product, class: 'space-y-6 pt-2' %}
        
        <!-- Sizing selection -->
        {% if product.variants.size > 1 %}
          <div class="space-y-2">
            <label class="text-[10px] text-neutral-400 font-bold uppercase tracking-wider block">
              Select Variant
            </label>
            <select name="id" id="ProductSelect" class="w-full text-xs px-4 py-3 border border-neutral-200 focus:outline-none focus:border-brandAccent rounded-none bg-white">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %}>
                  {{ variant.title }} - {{ variant.price | money }}
                </option>
              {% endfor %}
            </select>
          </div>
        {% else %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          
          <div class="space-y-2">
            <span class="text-[10px] text-neutral-400 font-bold uppercase tracking-wider">
              Select Packaging Size
            </span>
            <div class="grid grid-cols-2 gap-3">
              <button type="button" class="py-2.5 px-4 border border-brandPrimary bg-brandPrimary text-white text-xs text-center tracking-wider font-semibold rounded-none">
                Standard 250g Bag
              </button>
              <button type="button" class="py-2.5 px-4 border border-neutral-200 text-neutral-700 bg-transparent text-xs text-center tracking-wider font-semibold rounded-none hover:border-neutral-400">
                Bulk 1.0kg Bag
              </button>
            </div>
          </div>
        {% endif %}

        <!-- Grind options representation -->
        <div class="space-y-2">
          <span class="text-[10px] text-neutral-400 font-bold uppercase tracking-wider">
            Select Grind Profile
          </span>
          <div class="grid grid-cols-2 gap-2">
            <button type="button" class="py-2 px-3 border border-brandPrimary bg-brandPrimary text-white text-xs text-left transition-all flex justify-between items-center rounded-none">
              <span>Whole Beans</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </button>
            <button type="button" class="py-2 px-3 border border-neutral-200 text-neutral-600 bg-transparent text-xs text-left transition-all flex justify-between items-center rounded-none hover:border-neutral-400">
              <span>Filter Grind</span>
            </button>
          </div>
        </div>

        <!-- Add to Cart Button -->
        <div class="pt-4 flex gap-4">
          <div class="flex items-center border border-neutral-200">
            <button type="button" class="px-3 py-2 text-neutral-500 hover:text-neutral-900" onclick="this.parentNode.querySelector('input[type=number]').stepDown()">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            </button>
            <input type="number" id="Quantity" name="quantity" value="1" min="1" class="w-12 text-center text-xs border-none focus:outline-none bg-white">
            <button type="button" class="px-3 py-2 text-neutral-500 hover:text-neutral-900" onclick="this.parentNode.querySelector('input[type=number]').stepUp()">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            </button>
          </div>

          <button
            type="submit"
            name="add"
            class="flex-grow bg-brandPrimary text-white font-bold text-xs py-4.5 uppercase tracking-widest hover:bg-neutral-800 transition-all text-center flex items-center justify-center gap-2 rounded-none"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4.5 w-4.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            <span>Add to Cart</span>
          </button>
        </div>

      {% endform %}

      <!-- Tab sections like Profile, Brew, Origin -->
      <div class="border border-neutral-100 bg-brandCardBg p-5 space-y-4">
        <div class="flex border-b border-neutral-200 pb-2 gap-4 text-xs font-bold tracking-widest uppercase text-neutral-400">
          <span class="text-brandPrimary border-b-2 border-brandAccent pb-2 cursor-pointer">Sensory Profile</span>
          <span class="hover:text-brandPrimary cursor-pointer">Brewing Parameters</span>
        </div>
        <div class="text-xs text-neutral-600 leading-relaxed font-light space-y-2">
          <p>This micro-lot highlights raw origin purity. Meticulously roasted on a state-of-the-art fully monitored air roaster to ensure zero convective scorching or bitterness, leaving only pristine origin florals and clean geographic acidity.</p>
        </div>
      </div>

    </div>

  </div>
</div>

{% schema %}
{
  "name": "Product Details",
  "settings": []
}
{% endschema %}
