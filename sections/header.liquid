<header class="border-b border-neutral-200/40 bg-[#FAF9F6] sticky top-0 z-50 font-sans">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      
      <!-- Left: Navigation (Hidden on mobile, elegant on desktop) -->
      <nav class="hidden md:flex items-center space-x-8 text-xs font-medium tracking-widest uppercase">
        <a href="/" class="hover:text-neutral-500 transition-colors">Catalog</a>
        <a href="/pages/about" class="hover:text-neutral-500 transition-colors">About</a>
        <a href="/pages/wholesale" class="hover:text-neutral-500 transition-colors">Wholesale</a>
      </nav>

      <!-- Center: Logo / Shop Name -->
      <div class="flex-1 flex justify-center md:justify-center">
        <a href="/" class="text-lg font-light tracking-[0.3em] uppercase text-neutral-900 flex items-center gap-2">
          <span>ONE HALF</span>
          <span class="text-neutral-400 font-extralight">COFFEE</span>
        </a>
      </div>

      <!-- Right: Cart & Utilities -->
      <div class="flex items-center space-x-6 text-xs uppercase tracking-widest">
        <a href="/cart" class="flex items-center gap-1.5 hover:text-neutral-500 transition-colors font-medium">
          <span>Cart</span>
          <span class="bg-neutral-900 text-white rounded-full text-[9px] w-4 h-4 flex items-center justify-center font-mono font-bold">{{ cart.item_count }}</span>
        </a>
      </div>

    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
