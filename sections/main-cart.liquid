<div class="max-w-4xl mx-auto px-4 md:px-6 py-12 md:py-20 font-sans space-y-10">
  
  <div class="text-center space-y-3">
    <span class="text-[10px] tracking-[0.4em] uppercase font-bold text-brandAccent block">
      Your Selections
    </span>
    <h1 class="text-3xl md:text-4.5xl font-light tracking-tight text-neutral-900 font-serif">
      Shopping Cart
    </h1>
    <div class="w-12 h-[2px] mx-auto bg-brandAccent"></div>
  </div>

  {% if cart.item_count > 0 %}
    <form action="/cart" method="post" class="space-y-8">
      
      <!-- Cart Table -->
      <div class="border border-neutral-100 divide-y divide-neutral-100 bg-white">
        {% for item in cart.items %}
          <div class="p-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
            
            <div class="flex items-center gap-4">
              <!-- Image -->
              <div class="h-20 w-20 bg-stone-50 border border-neutral-100 shrink-0 overflow-hidden">
                {% if item.image %}
                  <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}" class="h-full w-full object-cover">
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'h-full w-full' }}
                {% endif %}
              </div>
              
              <!-- Info -->
              <div class="space-y-1">
                <h3 class="text-sm font-bold text-neutral-900 tracking-tight">
                  <a href="{{ item.url }}" class="hover:underline">{{ item.product.title }}</a>
                </h3>
                {% unless item.product.has_only_default_variant %}
                  <p class="text-xs text-neutral-500">{{ item.variant.title }}</p>
                {% endunless %}
                <p class="text-xs text-brandAccent font-mono">{{ item.original_line_price | money }}</p>
              </div>
            </div>

            <!-- Quantity & Actions -->
            <div class="flex items-center gap-6 w-full sm:w-auto justify-between sm:justify-end">
              <div class="flex items-center border border-neutral-200">
                <button type="submit" name="update" class="px-3 py-1.5 text-neutral-500 hover:text-neutral-900 text-sm">-</button>
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" class="w-12 text-center text-xs border-none focus:outline-none bg-white">
                <button type="submit" name="update" class="px-3 py-1.5 text-neutral-500 hover:text-neutral-900 text-sm">+</button>
              </div>

              <div class="text-right">
                <span class="text-sm font-bold text-neutral-900 font-mono">{{ item.final_line_price | money }}</span>
                <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="block text-[10px] text-red-500 hover:underline tracking-wider font-semibold uppercase mt-1">
                  Remove
                </a>
              </div>
            </div>

          </div>
        {% endfor %}
      </div>

      <!-- Footer Subtotal -->
      <div class="flex flex-col items-end space-y-4">
        <div class="space-y-1 text-right">
          <span class="text-xs text-neutral-400 font-bold uppercase tracking-widest block">Subtotal Amount</span>
          <span class="text-2xl font-bold text-neutral-900 font-mono">{{ cart.total_price | money }}</span>
          <p class="text-xs text-neutral-500 font-light italic">Taxes and shipping calculated at checkout.</p>
        </div>

        <div class="flex gap-4 w-full sm:w-auto">
          <button type="submit" name="update" class="px-6 py-3 border border-neutral-300 text-xs font-bold uppercase tracking-widest hover:bg-neutral-50 transition-colors bg-white rounded-none">
            Update Cart
          </button>
          <button type="submit" name="checkout" class="flex-grow sm:flex-grow-0 px-10 py-3 bg-brandPrimary text-white text-xs font-bold uppercase tracking-widest hover:bg-neutral-800 transition-all rounded-none">
            Checkout Securely
          </button>
        </div>
      </div>

    </form>
  {% else %}
    <!-- Empty state -->
    <div class="text-center py-16 border border-neutral-100 bg-brandCardBg space-y-4">
      <div class="h-12 w-12 rounded-full bg-neutral-100 flex items-center justify-center mx-auto text-neutral-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
      </div>
      <h3 class="text-lg font-bold text-neutral-800 tracking-tight">Your Cart is Empty</h3>
      <p class="text-xs text-neutral-500 font-light max-w-sm mx-auto">
        You haven't added any premium micro-lot roasted bags to your cart yet.
      </p>
      <div class="pt-2">
        <a href="/collections/all" class="inline-block px-8 py-3 bg-brandAccent text-white text-xs font-bold uppercase tracking-widest hover:opacity-90 transition-opacity rounded-none">
          Start Exploring
        </a>
      </div>
    </div>
  {% endif %}

</div>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
