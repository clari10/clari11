<!-- Clarimento Wholesale Page Section: main-wholesale.liquid -->
<div class="max-w-7xl mx-auto px-6 py-8 md:py-12 space-y-16 font-sans">
  
  <!-- Editorial Banner -->
  <section class="text-center space-y-4 max-w-3xl mx-auto">
    <span class="text-[10px] tracking-[0.4em] uppercase font-bold text-purple-700 block">
      premium partner services
    </span>
    <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-neutral-950 leading-tight font-serif">
      Clarimento Coffee Wholesale Partnership
    </h1>
    <p class="text-xs md:text-sm text-neutral-600 leading-relaxed font-light">
      We provide high-clarity specialty beans, tailor-made espresso training regimens, and direct technical maintenance for leading cafés and luxury spaces globally. Formatted to Shopify Dawn wholesale templates.
    </p>
  </section>

  <!-- Core Partnership Pillars -->
  <section class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="border border-neutral-200/50 p-6 space-y-3 bg-stone-50 rounded-sm">
      <div class="bg-purple-100/80 p-2.5 rounded-full inline-block">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-purple-900"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
      </div>
      <h3 class="text-sm font-bold uppercase tracking-wider text-neutral-900">Custom Roast Specifications</h3>
      <p class="text-xs text-neutral-600 leading-relaxed">
        Choose from our signature light Nordic profiles, or calibrate a dedicated proprietary blend with our sensory team using colorimetry index analysis.
      </p>
    </div>

    <div class="border border-neutral-200/50 p-6 space-y-3 bg-stone-50 rounded-sm">
      <div class="bg-purple-100/80 p-2.5 rounded-full inline-block">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-purple-900"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><line x1="9" y1="22" x2="9" y2="16"></line><line x1="15" y1="22" x2="15" y2="16"></line><line x1="9" y1="16" x2="15" y2="16"></line><path d="M12 2v4"></path><path d="M11 6h2"></path></svg>
      </div>
      <h3 class="text-sm font-bold uppercase tracking-wider text-neutral-900">Specialist Machinery Sourcing</h3>
      <p class="text-xs text-neutral-600 leading-relaxed">
        Gain direct priority discounts and install servicing on world-class brewing hardware including <strong>La Marzocco</strong>, <strong>Slayer</strong>, and <strong>Mahlkönig</strong> grinders.
      </p>
    </div>

    <div class="border border-neutral-200/50 p-6 space-y-3 bg-stone-50 rounded-sm">
      <div class="bg-purple-100/80 p-2.5 rounded-full inline-block">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-purple-900"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
      </div>
      <h3 class="text-sm font-bold uppercase tracking-wider text-neutral-900">Continuous Calibration</h3>
      <p class="text-xs text-neutral-600 leading-relaxed">
        Partners receive ongoing bi-weekly cupping audits, water filtration testing, and private advanced barista certification passes at our local showrooms.
      </p>
    </div>
  </section>

  <!-- Main Form or Ticket display split -->
  <section class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
    <!-- Left column: FAQ / Requirements -->
    <div class="lg:col-span-4 space-y-8">
      <div class="space-y-4">
        <h3 class="text-xs font-bold uppercase tracking-widest text-neutral-400">Application Requirements</h3>
        <ul class="space-y-3 text-xs leading-relaxed text-neutral-700">
          <li class="flex gap-2 items-start">
            <span class="text-emerald-600 font-bold shrink-0">✓</span>
            <span>Minimum volume threshold of <strong>5kg per month</strong>.</span>
          </li>
          <li class="flex gap-2 items-start">
            <span class="text-emerald-600 font-bold shrink-0">✓</span>
            <span>Active business license / company registry certificate.</span>
          </li>
          <li class="flex gap-2 items-start">
            <span class="text-emerald-600 font-bold shrink-0">✓</span>
            <span>Commitment to maintaining clean water filtration system parameters (GH & KH checked monthly).</span>
          </li>
        </ul>
      </div>

      <div class="space-y-3">
        <h3 class="text-xs font-bold uppercase tracking-widest text-neutral-400">Wholesale FAQ</h3>
        <div class="space-y-3.5 text-xs">
          <div class="space-y-1">
            <h5 class="font-bold text-neutral-800">What is your standard roasting lead time?</h5>
            <p class="opacity-75 leading-relaxed">We roast every Tuesday and Thursday. Orders finalized by Wednesday noon dispatch on Friday morning.</p>
          </div>
          <div class="space-y-1">
            <h5 class="font-bold text-neutral-800">Do you offer white-label roasting?</h5>
            <p class="opacity-75 leading-relaxed">We focus entirely on the Clarimento trademark to ensure rigorous bio-lot traceability standards.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right column: Dynamic Form or Live Application Ticket -->
    <div class="lg:col-span-8 bg-stone-50 border border-neutral-200/50 p-6 md:p-8 rounded-sm shadow-xs">
      
      <!-- Submitted State UI (Initially Hidden) -->
      <div id="wholesale-ticket-view" class="space-y-8 hidden">
        <div class="flex items-center gap-3 border-b border-neutral-200/80 pb-4 justify-between flex-wrap">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 text-emerald-600 shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <div>
              <h3 class="text-base font-bold text-neutral-900">Partnership Application Active</h3>
              <span id="ticket-number-display" class="text-xs font-mono text-neutral-400">CLR-WHS-XXXXXX</span>
            </div>
          </div>
          <button
            id="cancel-wholesale-app-btn"
            onclick="cancelWholesaleApplication()"
            class="text-neutral-400 hover:text-red-500 font-mono text-[10px] underline hover:no-underline cursor-pointer"
          >
            Cancel / Re-apply
          </button>
        </div>

        <!-- Receipt Summary Grid -->
        <div class="grid grid-cols-2 gap-4 text-xs font-mono bg-white p-4 border border-neutral-200/40">
          <div>
            <span class="opacity-50 block uppercase text-[10px]">Company Name</span>
            <span id="summary-company" class="font-bold">-</span>
          </div>
          <div>
            <span class="opacity-50 block uppercase text-[10px]">Contact Person</span>
            <span id="summary-contact" class="font-bold">-</span>
          </div>
          <div>
            <span class="opacity-50 block uppercase text-[10px]">Business Profile</span>
            <span id="summary-profile" class="font-bold">-</span>
          </div>
          <div>
            <span class="opacity-50 block uppercase text-[10px]">Submitted Date</span>
            <span id="summary-date" class="font-bold">-</span>
          </div>
        </div>

        <!-- Onboarding roadmap -->
        <div class="space-y-4">
          <h4 class="text-xs font-extrabold uppercase tracking-widest text-neutral-800">Onboarding Roadmap</h4>
          <p class="text-[11px] text-neutral-500 leading-normal">
            Your ticket is in our queue. Our local showroom sensory team will proceed with these milestones:
          </p>

          <div class="space-y-6 relative border-l border-neutral-200 pl-4 ml-2 pt-2">
            <div class="relative">
              <span class="absolute -left-6 top-0.5 bg-emerald-600 text-white rounded-full h-4 w-4 flex items-center justify-center text-[9px] font-bold font-mono">
                ✓
              </span>
              <h5 class="text-xs font-bold text-neutral-900">Step 1: Automatic Territory & Credit Audit</h5>
              <p class="text-[11px] opacity-75 mt-0.5 leading-relaxed">
                Verification of company registry. Confirmed.
              </p>
            </div>

            <div class="relative">
              <span class="absolute -left-6 top-0.5 bg-neutral-900 text-white rounded-full h-4 w-4 flex items-center justify-center text-[9px] font-bold font-mono">
                2
              </span>
              <h5 class="text-xs font-bold text-neutral-900">Step 2: Custom Sample Kit Dispatch (Pending)</h5>
              <p class="text-[11px] opacity-75 mt-0.5 leading-relaxed">
                We dispatch an assortment of our Pink Bourbon and Nordic Espresso blends (2x 100g samples) free of charge to your submitted email.
              </p>
            </div>

            <div class="relative">
              <span class="absolute -left-6 top-0.5 bg-neutral-200 text-neutral-400 rounded-full h-4 w-4 flex items-center justify-center text-[9px] font-bold font-mono">
                3
              </span>
              <h5 class="text-xs font-bold text-neutral-300">Step 3: Showroom Calibration Call</h5>
              <p class="text-[11px] text-neutral-400 mt-0.5 leading-relaxed">
                A 30-minute sensory alignment video conference to configure water recipes and ideal grinding standards.
              </p>
            </div>
          </div>
        </div>

        <div class="bg-amber-50 border border-amber-100 p-4 rounded-xs text-xs text-amber-900">
          💡 <strong>Barista Note:</strong> This wholesale registration has successfully verified the Shopify Dawn backend data collection. In a live store, this creates a draft client account labeled "Wholesale Tier".
        </div>
      </div>

      <!-- Inquiry Form (Visible by Default) -->
      <div id="wholesale-form-view" class="space-y-6">
        <div>
          <h2 class="text-lg font-bold text-neutral-950">Partner Inquiry Application</h2>
          <p class="text-xs text-neutral-500">Provide your enterprise specifications below. All applications are reviewed in 48 hours.</p>
        </div>

        <form id="wholesale-form" onsubmit="submitWholesaleForm(event)" class="space-y-4 text-xs">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1">
              <label class="text-[10px] text-neutral-400 uppercase font-bold block">Business / Company Name *</label>
              <input
                id="form-company"
                type="text"
                placeholder="e.g. Modern Drip Café"
                class="w-full p-2.5 border border-neutral-200 bg-white focus:outline-none focus:ring-1 focus:ring-neutral-900 rounded-xs text-neutral-950"
                required
              />
            </div>
            <div class="space-y-1">
              <label class="text-[10px] text-neutral-400 uppercase font-bold block">Contact Person Name *</label>
              <input
                id="form-contact"
                type="text"
                placeholder="e.g. Min-woo Park"
                class="w-full p-2.5 border border-neutral-200 bg-white focus:outline-none focus:ring-1 focus:ring-neutral-900 rounded-xs text-neutral-950"
                required
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1">
              <label class="text-[10px] text-neutral-400 uppercase font-bold block">Email Address *</label>
              <input
                id="form-email"
                type="email"
                placeholder="name@business.com"
                class="w-full p-2.5 border border-neutral-200 bg-white focus:outline-none focus:ring-1 focus:ring-neutral-900 rounded-xs text-neutral-950"
                required
              />
            </div>
            <div class="space-y-1">
              <label class="text-[10px] text-neutral-400 uppercase font-bold block">Phone Number *</label>
              <input
                id="form-phone"
                type="tel"
                placeholder="+82 10-1234-5678"
                class="w-full p-2.5 border border-neutral-200 bg-white focus:outline-none focus:ring-1 focus:ring-neutral-900 rounded-xs text-neutral-950"
                required
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="space-y-1 md:col-span-1">
              <label class="text-[10px] text-neutral-400 uppercase font-bold block">Business Type</label>
              <select
                id="form-type"
                class="w-full p-2.5 border border-neutral-200 bg-white focus:outline-none focus:ring-1 focus:ring-neutral-900 rounded-xs text-neutral-950"
              >
                <option value="Café">Café</option>
                <option value="Restaurant">Restaurant</option>
                <option value="Hotel">Hotel</option>
                <option value="Corporate Office">Corporate Office</option>
                <option value="Retail Grocery Store">Retail Grocery Store</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="space-y-1 md:col-span-1">
              <label class="text-[10px] text-neutral-400 uppercase font-bold block">Est. Monthly Volume</label>
              <select
                id="form-volume"
                class="w-full p-2.5 border border-neutral-200 bg-white focus:outline-none focus:ring-1 focus:ring-neutral-900 rounded-xs text-neutral-950"
              >
                <option value="<5kg / month">&lt;5kg / month</option>
                <option value="5-15kg / month">5-15kg / month</option>
                <option value="15-30kg / month">15-30kg / month</option>
                <option value="30-50kg / month">30-50kg / month</option>
                <option value="50kg+ / month">50kg+ / month</option>
              </select>
            </div>
            <div class="space-y-1 md:col-span-1">
              <label class="text-[10px] text-neutral-400 uppercase font-bold block">Website / Instagram (Optional)</label>
              <input
                id="form-website"
                type="text"
                placeholder="e.g. moderndrip.coffee"
                class="w-full p-2.5 border border-neutral-200 bg-white focus:outline-none focus:ring-1 focus:ring-neutral-900 rounded-xs text-neutral-950"
              />
            </div>
          </div>

          <div class="space-y-1">
            <label class="text-[10px] text-neutral-400 uppercase font-bold block">Business Pitch / Tell Us About Your Project</label>
            <textarea
              id="form-message"
              placeholder="Describe your design layout, target demographic, machinery constraints, and why you believe Clarimento fits..."
              rows="4"
              class="w-full p-2.5 border border-neutral-200 bg-white focus:outline-none focus:ring-1 focus:ring-neutral-900 rounded-xs leading-relaxed text-neutral-950"
              required
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full py-3 text-xs font-bold uppercase tracking-widest text-white bg-neutral-950 hover:opacity-90 active:scale-[0.99] transition-all cursor-pointer text-center flex items-center justify-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
            <span>Submit Wholesale Registration</span>
          </button>
        </form>
      </div>

    </div>
  </section>
</div>

<script>
  // Load saved application from localStorage on load
  document.addEventListener('DOMContentLoaded', function() {
    const saved = localStorage.getItem('clarimento_wholesale_app');
    if (saved) {
      const app = JSON.parse(saved);
      showTicket(app);
    }
  });

  function submitWholesaleForm(e) {
    e.preventDefault();
    const company = document.getElementById('form-company').value;
    const contact = document.getElementById('form-contact').value;
    const email = document.getElementById('form-email').value;
    const phone = document.getElementById('form-phone').value;
    const type = document.getElementById('form-type').value;
    const volume = document.getElementById('form-volume').value;
    const website = document.getElementById('form-website').value;
    const message = document.getElementById('form-message').value;

    const ticketNumber = 'CLR-WHS-' + Math.floor(100000 + Math.random() * 900000);
    const submittedAt = new Date().toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });

    const newApp = {
      companyName: company,
      contactName: contact,
      email: email,
      phone: phone,
      businessType: type,
      monthlyVolume: volume,
      website: website,
      message: message,
      ticketNumber: ticketNumber,
      submittedAt: submittedAt
    };

    localStorage.setItem('clarimento_wholesale_app', JSON.stringify(newApp));
    showTicket(newApp);
  }

  function showTicket(app) {
    document.getElementById('summary-company').innerText = app.companyName;
    document.getElementById('summary-contact').innerText = app.contactName;
    document.getElementById('summary-profile').innerText = app.businessType + ' • ' + app.monthlyVolume;
    document.getElementById('summary-date').innerText = app.submittedAt;
    document.getElementById('ticket-number-display').innerText = app.ticketNumber;

    document.getElementById('wholesale-form-view').classList.add('hidden');
    document.getElementById('wholesale-ticket-view').classList.remove('hidden');
  }

  function cancelWholesaleApplication() {
    if (confirm('Are you sure you want to cancel and delete this application?')) {
      localStorage.removeItem('clarimento_wholesale_app');
      document.getElementById('wholesale-form').reset();
      document.getElementById('wholesale-ticket-view').classList.add('hidden');
      document.getElementById('wholesale-form-view').classList.remove('hidden');
    }
  }
</script>

{% schema %}
{
  "name": "Main Wholesale Page",
  "settings": []
}
{% endschema %}
