<!-- Clarimento Recipes Page Section: main-recipes.liquid -->
<div class="max-w-7xl mx-auto px-4 md:px-8 py-12 md:py-20 font-sans">
  
  <!-- 1. Header Section -->
  <div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
    <span class="text-[10px] tracking-[0.4em] uppercase font-bold block text-purple-700">
      CLARIMENTO EXTRACTION LOG
    </span>
    <h1 class="text-3xl md:text-5xl font-light tracking-tight text-neutral-900 leading-tight font-serif">
      레시피 아카이브 보드
    </h1>
    <p class="text-xs md:text-sm text-neutral-500 leading-relaxed max-w-xl mx-auto font-light">
      세이 커피의 엄격한 라이트 로스트 가이드라인부터 바리스타가 일상적으로 연구하고 축적해온 다양한 추출 레시피를 하나의 통합 보드 형태로 기록하고 확인합니다.
    </p>
  </div>

  <!-- 2. Controls Menu: Search, Filter & Log Creator triggers -->
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-neutral-200/50 pb-8 mb-12">
    
    <!-- Left: Method Filters -->
    <div class="flex flex-wrap items-center gap-1.5 overflow-x-auto pb-1 md:pb-0">
      <button onclick="setRecipeMethodFilter('All')" id="filter-btn-All" class="recipe-filter-btn px-4 py-2 text-xs font-bold uppercase tracking-wider transition-all bg-neutral-950 text-white rounded-none">All</button>
      <button onclick="setRecipeMethodFilter('Hario V60')" id="filter-btn-HarioV60" class="recipe-filter-btn px-4 py-2 text-xs font-bold uppercase tracking-wider transition-all border border-neutral-200 hover:border-neutral-800 text-neutral-600 hover:text-neutral-900 rounded-none">Hario V60</button>
      <button onclick="setRecipeMethodFilter('Kalita Wave')" id="filter-btn-KalitaWave" class="recipe-filter-btn px-4 py-2 text-xs font-bold uppercase tracking-wider transition-all border border-neutral-200 hover:border-neutral-800 text-neutral-600 hover:text-neutral-900 rounded-none">Kalita Wave</button>
      <button onclick="setRecipeMethodFilter('Aeropress')" id="filter-btn-Aeropress" class="recipe-filter-btn px-4 py-2 text-xs font-bold uppercase tracking-wider transition-all border border-neutral-200 hover:border-neutral-800 text-neutral-600 hover:text-neutral-900 rounded-none">Aeropress</button>
      <button onclick="setRecipeMethodFilter('Espresso Machine')" id="filter-btn-Espresso" class="recipe-filter-btn px-4 py-2 text-xs font-bold uppercase tracking-wider transition-all border border-neutral-200 hover:border-neutral-800 text-neutral-600 hover:text-neutral-900 rounded-none">Espresso</button>
    </div>

    <!-- Right: Search Input & Add Button -->
    <div class="flex items-center gap-3">
      <div class="relative max-w-xs w-full">
        <input 
          id="recipe-search-input"
          type="text" 
          placeholder="원두명 또는 향미 태그 검색..."
          oninput="handleRecipeSearch(this.value)"
          class="w-full pl-8 pr-4 py-2.5 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950"
        />
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-3 text-neutral-400 h-4.5 w-4.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </div>

      <button
        onclick="toggleRecipeForm(true)"
        class="py-2.5 px-4 text-xs font-bold uppercase tracking-widest text-white bg-purple-600 hover:bg-purple-700 active:scale-95 transition-all flex items-center gap-1.5 cursor-pointer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        <span>Write Log</span>
      </button>
    </div>

  </div>

  <!-- 3. Recipes Gallery Board Grid -->
  <div id="recipes-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Rendered dynamically by JavaScript -->
  </div>
  
  <div id="recipes-empty-state" class="hidden text-center py-20 border border-dashed border-neutral-200 bg-neutral-50">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 text-neutral-300 mx-auto mb-3"><path d="M18 8h1a4 4 0 0 1 0 8h-1"></path><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path><line x1="6" y1="1" x2="6" y2="4"></line><line x1="10" y1="1" x2="10" y2="4"></line><line x1="14" y1="1" x2="14" y2="4"></line></svg>
    <p class="text-xs text-neutral-500 font-light">등록된 추출 레시피가 없거나 검색 결과가 없습니다.</p>
  </div>

  <!-- 4. Recipe Details Modal -->
  <div id="recipe-details-modal" class="fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4 md:p-6 backdrop-blur-xs hidden">
    <div class="bg-white w-full max-w-2xl overflow-y-auto max-h-[90vh] border border-neutral-200 relative shadow-2xl">
      
      <!-- Close trigger -->
      <button
        onclick="closeRecipeDetails()"
        class="absolute top-4 right-4 p-2 text-neutral-400 hover:text-neutral-900 bg-white border border-neutral-150 rounded-full transition-all cursor-pointer z-10"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></svg>
      </button>

      <!-- Immersive Modal Image -->
      <div class="relative h-48 md:h-64 w-full bg-neutral-100">
        <img 
          id="modal-image"
          src="" 
          alt="Recipe Banner" 
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-neutral-900 via-neutral-900/30 to-transparent"></div>
        <div class="absolute bottom-4 left-6 text-white space-y-1">
          <div class="flex items-center gap-2">
            <span id="modal-method-tag" class="text-[10px] bg-white/20 px-2 py-0.5 rounded-sm font-mono uppercase tracking-widest">
              HARIO V60
            </span>
            <span id="modal-date" class="text-[10px] text-neutral-300 font-mono">2026.06.28</span>
          </div>
          <h2 id="modal-title" class="text-lg md:text-2xl font-bold tracking-tight">
            Recipe Name
          </h2>
        </div>
      </div>

      <div class="p-6 md:p-8 space-y-6">
        
        <!-- Bean description -->
        <div class="space-y-2">
          <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-widest block">대상 커피 원두</span>
          <p id="modal-bean" class="text-xs md:text-sm font-bold text-neutral-800">Colombia El Paraiso</p>
          <p id="modal-desc" class="text-xs text-neutral-500 leading-relaxed font-light">Description here</p>
        </div>

        <!-- Param Grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 py-4 border-t border-b border-neutral-100 font-mono text-center">
          <div class="space-y-0.5">
            <span class="text-[9px] text-neutral-400 block uppercase font-bold">Coffee Dose</span>
            <span id="modal-param-dose" class="text-xs font-bold text-neutral-800">15g</span>
          </div>
          <div class="space-y-0.5">
            <span class="text-[9px] text-neutral-400 block uppercase font-bold">Water Yield</span>
            <span id="modal-param-yield" class="text-xs font-bold text-neutral-800">240g</span>
          </div>
          <div class="space-y-0.5">
            <span class="text-[9px] text-neutral-400 block uppercase font-bold">Temperature</span>
            <span id="modal-param-temp" class="text-xs font-bold text-neutral-800">94°C</span>
          </div>
          <div class="space-y-0.5">
            <span class="text-[9px] text-neutral-400 block uppercase font-bold">Grind Setting</span>
            <span id="modal-param-grind" class="text-xs font-bold text-neutral-800">Medium</span>
          </div>
        </div>

        <!-- Flavor notes -->
        <div class="space-y-1.5">
          <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-widest block">추출 타겟 향미 (Tasting Profile)</span>
          <div id="modal-notes-container" class="flex flex-wrap gap-1.5">
            <!-- Rendered by JS -->
          </div>
        </div>

        <!-- Steps List -->
        <div class="space-y-4">
          <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-widest block">추출 가이드 타임라인</span>
          <div id="modal-steps-container" class="space-y-4">
            <!-- Rendered by JS -->
          </div>
        </div>

        <!-- Water Chemistry Tip -->
        <div class="p-4 bg-purple-50/50 border border-purple-100/40 rounded-sm space-y-1.5">
          <span class="text-[10px] font-bold text-purple-900 uppercase tracking-wider block flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 text-purple-700"><circle cx="12" cy="12" r="10"></circle><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon></svg>
            물 화학(Water Chemistry) 및 권장 사항
          </span>
          <p class="text-[11px] text-purple-950/80 leading-relaxed font-light">
            Clarimento의 모든 라이트 로스트 싱글 오리진은 물의 총 경도 50-70 ppm GH, 알칼리도 20-30 ppm KH를 추천합니다. 추출 완료 후 음료의 온도가 점진적으로 내려가면서 핵과류 고유의 깨끗한 과일 단맛이 극적으로 열리기 시작하므로 서두르지 말고 느긋하게 음미하세요.
          </p>
        </div>

        <!-- Modal footer -->
        <div class="pt-4 border-t border-neutral-100 flex justify-between items-center text-[11px] text-neutral-400 font-mono">
          <span id="modal-footer-time">Total Target: 2:50 mins</span>
          <button
            onclick="closeRecipeDetails()"
            class="px-4 py-2 text-xs border border-neutral-200 text-neutral-600 hover:border-neutral-800 transition-all cursor-pointer font-bold uppercase tracking-wider"
          >
            창 닫기
          </button>
        </div>

      </div>

    </div>
  </div>

  <!-- 5. Create Recipe Form Overlay Drawer -->
  <div id="recipe-form-modal" class="fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4 md:p-6 backdrop-blur-xs hidden">
    <div class="bg-white w-full max-w-xl overflow-y-auto max-h-[90vh] border border-neutral-200 relative shadow-2xl p-6 md:p-8">
      
      <button
        onclick="toggleRecipeForm(false)"
        class="absolute top-4 right-4 p-1 text-neutral-400 hover:text-neutral-900 bg-white border border-neutral-150 rounded-full cursor-pointer transition-all z-10"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></svg>
      </button>

      <div class="space-y-1 mb-6">
        <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-widest block">EXTRACT LOG WRITER</span>
        <h2 class="text-xl font-bold tracking-tight text-neutral-900">추출 레시피 기록서 작성</h2>
        <p class="text-xs text-neutral-500 font-light leading-normal">
          커피를 내리면서 기록하고 싶은 추출 정보 및 변수를 빠짐없이 기입해 보세요.
        </p>
      </div>

      <form onsubmit="submitRecipeForm(event)" class="space-y-4 text-neutral-950">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="space-y-1">
            <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">레시피 이름 *</label>
            <input
              id="new-recipe-name"
              type="text"
              required
              placeholder="예: 아이스 하리오 플로럴 드립"
              class="w-full px-3 py-2 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 font-light"
            />
          </div>
          <div class="space-y-1">
            <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">원두 종류 & 가공방식 *</label>
            <input
              id="new-recipe-bean"
              type="text"
              required
              placeholder="예: 에티오피아 시다마 내추럴"
              class="w-full px-3 py-2 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 font-light"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="space-y-1">
            <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">추출 도구 (Method)</label>
            <select
              id="new-recipe-method"
              class="w-full px-3 py-2 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 font-medium"
            >
              <option value="Hario V60">Hario V60</option>
              <option value="Kalita Wave">Kalita Wave</option>
              <option value="Aeropress">Aeropress</option>
              <option value="Espresso Machine">Espresso Machine</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="space-y-1">
            <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">추출 비율 (Ratio)</label>
            <input
              id="new-recipe-ratio"
              type="text"
              value="1:16"
              placeholder="예: 1:16"
              class="w-full px-3 py-2 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 font-mono"
            />
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          <div class="space-y-1">
            <label class="text-[9px] text-neutral-400 uppercase font-bold tracking-wider block">원두 양 (g)</label>
            <input
              id="new-recipe-dose"
              type="number"
              step="0.1"
              value="15"
              class="w-full px-2.5 py-1.5 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 font-mono"
            />
          </div>
          <div class="space-y-1">
            <label class="text-[9px] text-neutral-400 uppercase font-bold tracking-wider block">물 주입량 (g)</label>
            <input
              id="new-recipe-yield"
              type="number"
              value="240"
              class="w-full px-2.5 py-1.5 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 font-mono"
            />
          </div>
          <div class="space-y-1">
            <label class="text-[9px] text-neutral-400 uppercase font-bold tracking-wider block">추출 온도</label>
            <input
              id="new-recipe-temp"
              type="text"
              value="94°C"
              placeholder="94°C"
              class="w-full px-2.5 py-1.5 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 font-mono"
            />
          </div>
          <div class="space-y-1">
            <label class="text-[9px] text-neutral-400 uppercase font-bold tracking-wider block">총 시간</label>
            <input
              id="new-recipe-time"
              type="text"
              value="3:00 mins"
              placeholder="3:00 mins"
              class="w-full px-2.5 py-1.5 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 font-mono"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="space-y-1">
            <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">분쇄도 세팅 (Grind size)</label>
            <input
              id="new-recipe-grind"
              type="text"
              value="Medium-Coarse"
              placeholder="예: 코만단테 25클릭"
              class="w-full px-3 py-2 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 font-light"
            />
          </div>
          <div class="space-y-1">
            <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">컵 향미 노트 (콤마로 구분)</label>
            <input
              id="new-recipe-notes"
              type="text"
              placeholder="자스민, 사과, 메이플시럽"
              class="w-full px-3 py-2 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 font-light"
            />
          </div>
        </div>

        <div class="space-y-1">
          <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">레시피 한 줄 소개</label>
          <input
            id="new-recipe-desc"
            type="text"
            placeholder="예: 첫 모금에 화사한 베리 향을 풍부하게 가미한 산뜻한 아침 브루잉 가이드."
            class="w-full px-3 py-2 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 font-light"
          />
        </div>

        <div class="space-y-1">
          <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">상세 추출 가이드 단계 (엔터로 줄 구분)</label>
          <textarea
            id="new-recipe-steps"
            rows="4"
            placeholder="예:&#10;1. 40g의 물을 부어 약 40초간 뜸을 들입니다.&#10;2. 나선형으로 부드럽게 100g까지 부어줍니다.&#10;3. 물이 다 빠지기 전에 마지막 푸어를 마칩니다."
            class="w-full px-3 py-2 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 font-light leading-relaxed"
          ></textarea>
        </div>

        <div class="flex gap-3 pt-4 border-t border-neutral-100">
          <button
            type="button"
            onclick="toggleRecipeForm(false)"
            class="w-1/3 py-3 border border-neutral-200 text-neutral-500 font-bold uppercase tracking-widest text-[10px] hover:border-neutral-400 transition-all cursor-pointer text-center bg-white"
          >
            작성 취소
          </button>
          <button
            type="submit"
            class="w-2/3 py-3 font-bold uppercase tracking-widest text-[10px] bg-purple-600 text-white hover:opacity-90 active:scale-[0.99] transition-all cursor-pointer text-center flex items-center justify-center gap-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            <span>레시피 보드 등록하기</span>
          </button>
        </div>

      </form>

    </div>
  </div>

</div>

<script>
  // Recipes data array
  let recipes = [];
  let filterMethod = 'All';
  let searchQuery = '';

  const DEFAULT_RECIPES = [
    {
      id: 'v60-clarity',
      name: 'Signature Clarity Pour-over',
      bean: 'Colombia El Paraiso Pink Bourbon (Double Anaerobic)',
      method: 'Hario V60',
      ratio: '1:16',
      coffeeGrams: 15,
      waterGrams: 240,
      temp: '94°C',
      time: '2:50 mins',
      grind: 'Medium-Coarse',
      notes: ['Peach', 'Jasmine', 'Strawberry Yogurt', 'Honey'],
      description: '무산소 발효 생두 고유의 화려한 복합미와 복숭아 요거트 같은 독창적인 단맛을 온전히 컵으로 이끌어내기 위한 세이 스타일 표준 레시피.',
      steps: [
        '종이 필터를 뜨거운 물로 린싱하여 미분을 씻어내고 서버를 예열한 뒤 물을 버려줍니다.',
        '분쇄 원두 15g을 고르게 담은 후, 저울의 영점을 세팅합니다.',
        '뜸들이기(Bloom): 94°C의 뜨거운 물 45g을 부어 전체 원두를 고루 적셔줍니다. 스푼이나 스틱으로 가볍게 저어준 뒤 45초 동안 기다려 가스를 방출합니다.',
