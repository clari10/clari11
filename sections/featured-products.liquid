<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20 font-sans">
  
  <div class="text-center max-w-2xl mx-auto space-y-3 mb-16">
    <span class="text-[9px] tracking-[0.4em] uppercase font-black block opacity-60 text-neutral-400">
      SEASONAL SELECTION
    </span>
    <h2 class="text-2xl md:text-3xl font-light tracking-tight text-neutral-900 font-serif">
      The Micro-Lot Catalog
    </h2>
    <p class="text-xs text-neutral-400 font-light max-w-md mx-auto">
      Light-roast profiles roasted with complete clarity, absolute sweetness, and structured transparency.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-12">
    {% for product in collections.all.products %}
      <div class="group cursor-pointer space-y-3 flex flex-col justify-between relative">
        <div class="aspect-square w-full overflow-hidden border border-neutral-200/25 flex items-center justify-center transition-all duration-300 group-hover:border-neutral-300/60 relative bg-[#FAF9F6]">
          {% if product.featured_image %}
            <img 
              src="{{ product.featured_image | image_url: width: 600 }}" 
              alt="{{ product.title | escape }}"
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.025]"
              loading="lazy"
            >
          {% else %}
            {{ 'product-3' | placeholder_svg_tag: 'w-full h-full' }}
          {% endif %}

          <!-- Slide up Add-to-Cart -->
          <div class="absolute bottom-0 left-0 right-0 transform translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out z-10">
            <form action="/cart/add" method="post" enctype="multipart/form-data">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button
                type="submit"
                class="w-full py-3 bg-neutral-950/95 hover:bg-neutral-900 text-white text-[9px] uppercase tracking-[0.2em] font-bold transition-all flex items-center justify-center gap-1.5 cursor-pointer"
              >
                <span>Quick Add</span>
              </button>
            </form>
          </div>
        </div>

        <div class="text-center space-y-1.5 pt-2">
          <h4 class="text-xs md:text-sm font-normal text-neutral-800 tracking-tight transition-colors group-hover:text-neutral-500">
            <a href="{{ product.url }}">{{ product.title }}</a>
          </h4>
          <div class="text-[10px] text-neutral-500 font-mono">
            {{ product.price | money }} USD
          </div>
        </div>
      </div>
    {% else %}
      {% for i in (1..3) %}
        <div class="space-y-3">
          <div class="aspect-square w-full bg-neutral-100 flex items-center justify-center border border-neutral-200/20">
            {{ 'product-' | append: i | placeholder_svg_tag: 'w-full h-full text-neutral-300' }}
          </div>
          <div class="text-center space-y-1">
            <h4 class="text-xs md:text-sm font-normal text-neutral-800">Sample Micro-Lot {{ i }}</h4>
            <div class="text-[10px] text-neutral-500 font-mono">$18.00 USD</div>
          </div>
        </div>
      {% endfor %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products Grid",
  "settings": [],
  "presets": [
    {
      "name": "Featured Products Grid"
    }
  ]
}
{% endschema %}
