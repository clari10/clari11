<!-- Clarimento Subscriptions Page Section: main-subscriptions.liquid -->
<div class="max-w-7xl mx-auto px-4 md:px-8 py-10 md:py-16 font-sans">
  
  <!-- Page Header -->
  <div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
    <span class="text-[10px] tracking-[0.4em] uppercase font-bold block text-purple-600 animate-pulse">
      SAY COFFEE SUBSCRIPTION
    </span>
    <h1 class="text-3xl md:text-5xl font-light tracking-tight text-neutral-900 leading-tight font-serif">
      정기 구독 서비스
    </h1>
    <p class="text-xs md:text-sm text-neutral-500 leading-relaxed max-w-xl mx-auto font-light">
      세이 커피의 시그니처 라이트 로스트 싱글 오리진부터 완벽하게 밸런스 잡힌 에스프레소까지, 매주 신선한 상태로 정기 배송 받아보세요.
    </p>
  </div>

  <!-- DASHBOARD VIEW: Show if active subscription exists (Controlled via JavaScript) -->
  <div id="sub-dashboard-view" class="max-w-4xl mx-auto bg-white border border-neutral-200/55 p-6 md:p-10 shadow-xs space-y-8 hidden animate-fade-in">
    
    <!-- Header Banner -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-neutral-200/40 pb-6">
      <div class="space-y-1.5">
        <div class="flex items-center gap-2.5 flex-wrap">
          <span id="dash-id" class="text-[10px] tracking-wider font-mono px-2 py-0.5 border border-neutral-200 text-neutral-500 bg-neutral-50 rounded-sm">
            ID: SUB-XXXXX
          </span>
          <span id="dash-status-badge" class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-0.5 rounded-sm bg-emerald-50 text-emerald-700 border border-emerald-100">
            ● 구독 활성
          </span>
        </div>
        <h2 id="dash-profile-title" class="text-xl font-bold tracking-tight text-neutral-900">
          필터 싱글오리진 (Filter Single Origin)
        </h2>
      </div>
      <div class="text-right">
        <span class="text-sm font-mono text-neutral-500">정기 결제금액</span>
        <p id="dash-price" class="text-2xl font-bold font-mono text-neutral-900">$40.00</p>
      </div>
    </div>

    <!-- Details Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 py-2">
      <div class="space-y-1">
        <span class="text-[10px] text-neutral-400 font-bold uppercase tracking-wider block">구독 구성</span>
        <p id="dash-config-desc" class="text-xs font-semibold text-neutral-800">2 Bags (500g) / Whole Bean</p>
      </div>
      <div class="space-y-1">
        <span class="text-[10px] text-neutral-400 font-bold uppercase tracking-wider block">배송 주기</span>
        <p id="dash-frequency-desc" class="text-xs font-semibold text-neutral-800">매 4주 마다 자동 배송</p>
      </div>
      <div class="space-y-1">
        <span class="text-[10px] text-neutral-400 font-bold uppercase tracking-wider block">다음 예정 발송일</span>
        <p id="dash-date-desc" class="text-xs font-semibold text-neutral-800 flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 text-neutral-400"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
          <span id="dash-next-date">2026년 7월 3일 월요일</span>
        </p>
      </div>
    </div>

    <hr class="border-neutral-200/40" />

    <!-- Delivery & Billing Info -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 py-2">
      <div class="space-y-2">
        <span class="text-[10px] text-neutral-400 font-bold uppercase tracking-wider block">배송 주소지</span>
        <div class="bg-neutral-50 p-4 border border-neutral-150 rounded-sm space-y-1 text-xs">
          <p class="font-bold text-neutral-800"><span id="dash-recipient-name">홍길동</span> <span id="dash-recipient-phone" class="font-normal text-neutral-500 font-mono">(010-1234-5678)</span></p>
          <p id="dash-recipient-address" class="text-neutral-600 leading-relaxed">서울특별시 강남구 테헤란로 123, 4층</p>
        </div>
      </div>
      <div class="space-y-2">
        <span class="text-[10px] text-neutral-400 font-bold uppercase tracking-wider block">결제 수단 정보</span>
        <div class="bg-neutral-50 p-4 border border-neutral-150 rounded-sm flex items-center justify-between text-xs">
          <div class="flex items-center gap-3">
            <div class="p-1.5 bg-neutral-200 text-neutral-700 rounded-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line x1="1" y1="10" x2="23" y2="10"></line></svg>
            </div>
            <div>
              <p id="dash-payment-card" class="font-bold text-neutral-800">•••• •••• •••• 5678</p>
              <p class="text-[10px] text-neutral-400">배송 주기마다 자동 승인 결제</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Control Actions -->
    <div class="flex flex-wrap items-center justify-between gap-4 pt-6 border-t border-neutral-200/40">
      <div class="flex items-center gap-3">
        <button
          onclick="toggleSubStatus()"
          id="toggle-sub-btn"
          class="py-2.5 px-4 text-xs font-semibold uppercase tracking-wider border border-neutral-200 hover:border-neutral-800 text-neutral-700 hover:text-neutral-900 transition-all cursor-pointer rounded-sm bg-white"
        >
          구독 일시정지
        </button>
        <button
          onclick="triggerShipNow()"
          id="ship-now-btn"
          class="py-2.5 px-4 text-xs font-semibold uppercase tracking-wider border border-neutral-200 hover:border-neutral-800 text-neutral-700 hover:text-neutral-900 transition-all cursor-pointer rounded-sm bg-white"
        >
          이번 주 원두 즉시 발송
        </button>
      </div>

      <button
        onclick="cancelSubscription()"
        class="py-2.5 px-4 text-xs font-semibold uppercase tracking-wider text-rose-500 hover:text-rose-700 transition-all cursor-pointer bg-transparent border-0"
      >
        구독 해지하기
      </button>
    </div>

  </div>

  <!-- CONFIGURATOR WIZARD VIEW (Controlled via JavaScript) -->
  <div id="sub-configurator-view" class="grid grid-cols-1 lg:grid-cols-12 gap-12 max-w-6xl mx-auto items-start">
    
    <!-- LEFT: Configurator Controls (7 Columns) -->
    <div class="lg:col-span-7 space-y-10">
      
      <!-- STEP 1: Plan Configuration Options -->
      <div id="step-1-container" class="space-y-8">
        
        <!-- 1. Coffee Profile selection -->
        <div class="space-y-4">
          <div class="flex justify-between items-baseline">
            <span class="text-[11px] font-bold text-neutral-400 uppercase tracking-[0.15em]">Step 01. 원두 프로파일 선택</span>
            <span class="text-xs text-neutral-500 font-mono">가장 고유하고 선명한 스타일</span>
          </div>
          <div class="space-y-3">
            
            <div
              onclick="selectSubProfile('filter')"
              id="profile-card-filter"
              class="sub-profile-card p-5 border transition-all cursor-pointer relative bg-neutral-950/2 border-neutral-900"
              style="border-radius: 6px;"
            >
              <div class="flex justify-between items-start mb-2">
                <h3 class="text-xs md:text-sm font-bold text-neutral-950">필터 싱글오리진 (Filter Roast Lot)</h3>
                <span class="text-[9px] font-mono font-bold px-2 py-0.5 tracking-wider bg-neutral-100 text-neutral-600 rounded-sm">BEST</span>
              </div>
              <p class="text-[11px] md:text-xs text-neutral-500 leading-relaxed font-light">Say Coffee 시그니처 라이트 로스트. 화려한 에티오피아 무산소 발효부터 극도의 클린컵을 주는 콜롬비아 핑크버번 등, 매주 수확기에 마스터가 엄선한 최고의 컵을 담아 배송합니다.</p>
              <div class="profile-accent-bar absolute left-0 top-0 bottom-0 w-[3px] bg-purple-600"></div>
            </div>

            <div
              onclick="selectSubProfile('espresso')"
              id="profile-card-espresso"
              class="sub-profile-card p-5 border transition-all cursor-pointer relative bg-white border-neutral-200 hover:border-neutral-400"
              style="border-radius: 6px;"
            >
              <div class="flex justify-between items-start mb-2">
                <h3 class="text-xs md:text-sm font-bold text-neutral-950">하우스 에스프레소 블렌드 (House Espresso)</h3>
                <span class="text-[9px] font-mono font-bold px-2 py-0.5 tracking-wider bg-neutral-100 text-neutral-600 rounded-sm">CLASSIC</span>
              </div>
              <p class="text-[11px] md:text-xs text-neutral-500 leading-relaxed font-light">풍부하고 고소한 단맛, 실키한 마우스필에 과일의 뉘앙스를 세련되게 담아낸 스위트 블렌드입니다. 에스프레소 머신 및 자동 브루잉 머신 전용으로 설계되었습니다.</p>
              <div class="profile-accent-bar absolute left-0 top-0 bottom-0 w-[3px] bg-purple-600 hidden"></div>
            </div>

            <div
              onclick="selectSubProfile('decaf')"
              id="profile-card-decaf"
              class="sub-profile-card p-5 border transition-all cursor-pointer relative bg-white border-neutral-200 hover:border-neutral-400"
              style="border-radius: 6px;"
            >
              <div class="flex justify-between items-start mb-2">
                <h3 class="text-xs md:text-sm font-bold text-neutral-950">스페셜티 디카페인 (Specialty Decaf)</h3>
                <span class="text-[9px] font-mono font-bold px-2 py-0.5 tracking-wider bg-neutral-100 text-neutral-600 rounded-sm">SAFE</span>
              </div>
              <p class="text-[11px] md:text-xs text-neutral-500 leading-relaxed font-light">천연 CO2 공법을 사용해 화학 물질 없이 안전하고 완벽하게 카페인만 분리했습니다. 스페셜티 고유의 단맛과 사과, 아몬드의 향미를 디카페인에서도 깊게 전합니다.</p>
              <div class="profile-accent-bar absolute left-0 top-0 bottom-0 w-[3px] bg-purple-600 hidden"></div>
            </div>

          </div>
        </div>

        <!-- 2. Bags Size selection -->
        <div class="space-y-4">
          <span class="text-[11px] font-bold text-neutral-400 uppercase tracking-[0.15em] block">Step 02. 수량 설정 (용량)</span>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            
            <div onclick="selectSubBags(1)" id="bags-card-1" class="sub-bags-card p-4 border text-center transition-all cursor-pointer relative bg-white border-neutral-200 hover:border-neutral-400" style="border-radius: 6px;">
              <p class="text-sm font-bold text-neutral-900">1 Bag</p>
              <p class="text-[10px] text-neutral-400 font-mono mt-0.5">250g</p>
              <span class="text-[9px] font-semibold text-neutral-500 block mt-2 px-1.5 py-0.5 bg-neutral-50 rounded-sm border border-neutral-100">기본가</span>
              <div class="bags-accent-bar absolute bottom-0 left-0 right-0 h-[3px] bg-purple-600 hidden"></div>
            </div>

            <div onclick="selectSubBags(2)" id="bags-card-2" class="sub-bags-card p-4 border text-center transition-all cursor-pointer relative bg-neutral-950/2 border-neutral-900" style="border-radius: 6px;">
              <p class="text-sm font-bold text-neutral-900">2 Bags</p>
              <p class="text-[10px] text-neutral-400 font-mono mt-0.5">500g</p>
              <span class="text-[9px] font-semibold text-neutral-500 block mt-2 px-1.5 py-0.5 bg-neutral-50 rounded-sm border border-neutral-100">Save $4.00</span>
              <div class="bags-accent-bar absolute bottom-0 left-0 right-0 h-[3px] bg-purple-600"></div>
            </div>

            <div onclick="selectSubBags(3)" id="bags-card-3" class="sub-bags-card p-4 border text-center transition-all cursor-pointer relative bg-white border-neutral-200 hover:border-neutral-400" style="border-radius: 6px;">
              <p class="text-sm font-bold text-neutral-900">3 Bags</p>
              <p class="text-[10px] text-neutral-400 font-mono mt-0.5">750g</p>
              <span class="text-[9px] font-semibold text-neutral-500 block mt-2 px-1.5 py-0.5 bg-neutral-50 rounded-sm border border-neutral-100">Save $8.00</span>
              <div class="bags-accent-bar absolute bottom-0 left-0 right-0 h-[3px] bg-purple-600 hidden"></div>
            </div>

            <div onclick="selectSubBags(4)" id="bags-card-4" class="sub-bags-card p-4 border text-center transition-all cursor-pointer relative bg-white border-neutral-200 hover:border-neutral-400" style="border-radius: 6px;">
              <p class="text-sm font-bold text-neutral-900">4 Bags</p>
              <p class="text-[10px] text-neutral-400 font-mono mt-0.5">1,000g</p>
              <span class="text-[9px] font-semibold text-neutral-500 block mt-2 px-1.5 py-0.5 bg-neutral-50 rounded-sm border border-neutral-100">Save $14.00</span>
              <div class="bags-accent-bar absolute bottom-0 left-0 right-0 h-[3px] bg-purple-600 hidden"></div>
            </div>

          </div>
        </div>

        <!-- 3. Frequency selection -->
        <div class="space-y-4">
          <span class="text-[11px] font-bold text-neutral-400 uppercase tracking-[0.15em] block">Step 03. 배송 주기 선택</span>
          <div class="grid grid-cols-2 gap-4">
            
            <div onclick="selectSubFrequency('2weeks')" id="freq-card-2weeks" class="sub-freq-card p-4 border transition-all cursor-pointer relative text-left bg-white border-neutral-200 hover:border-neutral-400" style="border-radius: 6px;">
              <h3 class="text-xs font-bold text-neutral-950 mb-1">매 2주 마다 발송</h3>
              <p class="text-[10px] text-neutral-500 leading-normal font-light">항상 신선하고 다채로운 원두 회전율을 희망할 경우 추천</p>
              <div class="freq-accent-bar absolute left-0 top-0 bottom-0 w-[3px] bg-purple-600 hidden"></div>
            </div>

            <div onclick="selectSubFrequency('4weeks')" id="freq-card-4weeks" class="sub-freq-card p-4 border transition-all cursor-pointer relative text-left bg-neutral-950/2 border-neutral-900" style="border-radius: 6px;">
              <h3 class="text-xs font-bold text-neutral-950 mb-1">매 4주 마다 (매월)</h3>
              <p class="text-[10px] text-neutral-500 leading-normal font-light">하루 1-2잔 가볍게 드시는 싱글 브루잉 가구에 추천</p>
              <div class="freq-accent-bar absolute left-0 top-0 bottom-0 w-[3px] bg-purple-600"></div>
            </div>

          </div>
        </div>

        <!-- 4. Grind option -->
        <div class="space-y-4">
          <span class="text-[11px] font-bold text-neutral-400 uppercase tracking-[0.15em] block">Step 04. 분쇄도 옵션 선택</span>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <div onclick="selectSubGrind('Whole Bean')" id="grind-card-WholeBean" class="sub-grind-card p-3 border text-center transition-all cursor-pointer text-xs font-semibold bg-neutral-950/2 text-neutral-950 border-neutral-900" style="border-radius: 6px;">홀빈 (분쇄 안함)</div>
            <div onclick="selectSubGrind('Espresso')" id="grind-card-Espresso" class="sub-grind-card p-3 border text-center transition-all cursor-pointer text-xs font-semibold bg-white text-neutral-500 border-neutral-200 hover:border-neutral-400" style="border-radius: 6px;">Espresso</div>
            <div onclick="selectSubGrind('Filter')" id="grind-card-Filter" class="sub-grind-card p-3 border text-center transition-all cursor-pointer text-xs font-semibold bg-white text-neutral-500 border-neutral-200 hover:border-neutral-400" style="border-radius: 6px;">Filter</div>
            <div onclick="selectSubGrind('French Press')" id="grind-card-FrenchPress" class="sub-grind-card p-3 border text-center transition-all cursor-pointer text-xs font-semibold bg-white text-neutral-500 border-neutral-200 hover:border-neutral-400" style="border-radius: 6px;">French Press</div>
          </div>
        </div>

      </div>

      <!-- STEP 2: Checkout Information Forms (Initially Hidden) -->
      <form id="step-2-form" onsubmit="submitSubscription(event)" class="space-y-8 bg-white p-6 md:p-8 border border-neutral-200/60 rounded-md hidden">
        <div class="flex justify-between items-center border-b border-neutral-100 pb-4 mb-4">
          <div>
            <span class="text-[10px] font-bold text-neutral-400 uppercase tracking-widest block">Step 02.</span>
            <h3 class="text-sm font-bold text-neutral-800">배송 및 결제정보 입력</h3>
          </div>
          <button 
            type="button"
            onclick="setStep(1)" 
            class="text-xs text-neutral-400 hover:text-neutral-700 flex items-center gap-1 font-semibold border-0 bg-transparent cursor-pointer"
          >
            이전 단계로
          </button>
        </div>

        <!-- Shipping Details -->
        <div class="space-y-4">
          <h4 class="text-xs uppercase tracking-wider font-bold text-neutral-400 border-b border-neutral-100 pb-2">배송지 정보</h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">수령인 성명 *</label>
              <input
                id="sub-recipient-name-input"
                type="text"
                required
                placeholder="홍길동"
                class="w-full px-3 py-2.5 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 rounded-[4px]"
              />
            </div>
            <div class="space-y-1.5">
              <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">연락처 *</label>
              <input
                id="sub-recipient-phone-input"
                type="tel"
                required
                placeholder="010-1234-5678"
                class="w-full px-3 py-2.5 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 rounded-[4px]"
              />
            </div>
          </div>
          <div class="space-y-1.5">
            <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">배송 주소 *</label>
            <input
              id="sub-recipient-address-input"
              type="text"
              required
              placeholder="서울특별시 강남구 테헤란로 123, 4층"
              class="w-full px-3 py-2.5 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 rounded-[4px]"
            />
          </div>
        </div>

        <!-- Payment Details -->
        <div class="space-y-4 pt-4">
          <h4 class="text-xs uppercase tracking-wider font-bold text-neutral-400 border-b border-neutral-100 pb-2">정기 결제 수단 (신용/체크카드)</h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">카드 번호 *</label>
              <input
                id="sub-card-number-input"
                type="text"
                required
                maxlength="19"
                placeholder="1234 - 5678 - 1234 - 5678"
                class="w-full px-3 py-2.5 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 rounded-[4px] font-mono"
              />
            </div>
            <div class="space-y-1.5">
              <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">소유자 성명 *</label>
              <input
                id="sub-card-name-input"
                type="text"
                required
                placeholder="GILDONG HONG"
                class="w-full px-3 py-2.5 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 rounded-[4px]"
              />
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="space-y-1.5">
              <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">유효 기한 *</label>
              <input
                type="text"
                required
                maxlength="5"
                placeholder="MM / YY"
                class="w-full px-3 py-2.5 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 rounded-[4px] font-mono"
              />
            </div>
            <div class="space-y-1.5">
              <label class="text-[10px] text-neutral-400 uppercase font-bold tracking-wider block">보안 코드 (CVC) *</label>
              <input
                type="password"
                required
                maxlength="3"
                placeholder="3자리"
                class="w-full px-3 py-2.5 border border-neutral-200 text-xs focus:border-neutral-950 focus:outline-none bg-white text-neutral-950 rounded-[4px] font-mono"
              />
            </div>
          </div>
        </div>

        <!-- Security Tag -->
        <div class="flex gap-2.5 items-start p-3 bg-neutral-50 border border-neutral-100 rounded-sm text-[11px] text-neutral-500 leading-normal">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-neutral-400 shrink-0 mt-0.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          <span>Clarimento 정기구독은 암호화된 자동결제 방식을 채택하고 있어 금융 정보 유출 위험이 전혀 없으며, 매 주기 발송 전에만 결제가 승인됩니다. 일시정지 및 언제든지 해지가 자유롭습니다.</span>
        </div>

        <!-- Actions -->
        <div class="flex gap-4 pt-2">
          <button
            type="button"
            onclick="setStep(1)"
            class="w-1/3 py-3 border border-neutral-200 text-neutral-500 font-bold uppercase tracking-widest text-[10px] hover:border-neutral-400 bg-white transition-all cursor-pointer text-center"
            style="border-radius: 4px;"
          >
            이전 단계
          </button>
          <button
            type="submit"
            id="sub-submit-btn"
            class="w-2/3 py-3 font-bold uppercase tracking-widest text-[10px] text-white bg-neutral-950 hover:opacity-90 active:scale-[0.99] transition-all cursor-pointer text-center flex items-center justify-center gap-2"
            style="border-radius: 4px;"
          >
            <span>구독 안전 결제 완료하기</span>
          </button>
        </div>
      </form>

    </div>

    <!-- RIGHT: Live Plan summary card (5 Columns) -->
    <div class="lg:col-span-5 sticky top-28 bg-white border border-neutral-200/50 p-6 md:p-8 space-y-6 shadow-xs">
      <h4 class="text-xs uppercase tracking-widest font-bold text-neutral-400">나의 정기구독 설계서</h4>
      
      <div class="space-y-4">
        <div class="flex justify-between items-start py-3 border-b border-neutral-100">
          <div class="space-y-1">
            <span class="text-[10px] text-neutral-400 font-bold uppercase tracking-wider block">프로파일</span>
            <span id="summary-profile-label" class="text-xs font-bold text-neutral-900">필터 싱글오리진</span>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-neutral-400"><path d="M18 8h1a4 4 0 0 1 0 8h-1"></path><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path><line x1="6" y1="1" x2="6" y2="4"></line><line x1="10" y1="1" x2="10" y2="4"></line><line x1="14" y1="1" x2="14" y2="4"></line></svg>
        </div>

        <div class="flex justify-between items-start py-3 border-b border-neutral-100">
          <div class="space-y-1">
            <span class="text-[10px] text-neutral-400 font-bold uppercase tracking-wider block">수량 (용량)</span>
            <span id="summary-bags-label" class="text-xs font-bold text-neutral-900">2 Bags (500g)</span>
          </div>
          <span id="summary-bags-price" class="text-xs font-mono text-neutral-500">$40.00</span>
        </div>

        <div class="flex justify-between items-start py-3 border-b border-neutral-100">
          <div class="space-y-1">
            <span class="text-[10px] text-neutral-400 font-bold uppercase tracking-wider block">배송 주기</span>
            <span id="summary-freq-label" class="text-xs font-bold text-neutral-900">매 4주 마다</span>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5 text-neutral-400"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        </div>

        <div class="flex justify-between items-start py-3 border-b border-neutral-100">
          <div class="space-y-1">
            <span class="text-[10px] text-neutral-400 font-bold uppercase tracking-wider block">선택된 분쇄도</span>
            <span id="summary-grind-label" class="text-xs font-bold text-neutral-900">Whole Bean</span>
          </div>
        </div>
      </div>

      <!-- Price breakdown -->
      <div class="bg-neutral-50 p-4 rounded-sm space-y-2 text-[11px]">
        <div class="flex justify-between text-neutral-500">
          <span>기본 정기 발송 요금</span>
          <span id="summary-breakdown-base" class="font-mono">$44.00</span>
        </div>
        <div class="flex justify-between text-emerald-600 font-semibold">
          <span>구독 전용 상시 특별 할인</span>
          <span id="summary-breakdown-discount" class="font-mono">-$4.00</span>
        </div>
        <div class="flex justify-between text-neutral-500">
          <span>스페셜티 직배송비</span>
          <span class="text-emerald-600 font-bold uppercase tracking-wider font-mono">FREE</span>
        </div>
        <hr class="border-neutral-200/50 my-1" />
        <div class="flex justify-between items-baseline pt-1">
          <span class="text-xs font-bold text-neutral-800">예상 결제 금액</span>
          <span id="summary-total-price" class="text-xl font-bold font-mono text-neutral-950">$40.00</span>
        </div>
      </div>

      <!-- Action trigger button inside card -->
      <button
        onclick="setStep(2)"
        id="summary-next-step-btn"
        class="w-full py-4 text-[10px] font-bold uppercase tracking-widest text-white bg-neutral-950 hover:opacity-90 active:scale-[0.99] transition-all flex items-center justify-center gap-2 cursor-pointer border-0"
        style="border-radius: 4px;"
      >
        <span>배송 정보 입력하기</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </button>

      <!-- Sourcing Promise tag -->
      <div class="border border-neutral-100 p-4 text-[10px] text-neutral-400 leading-relaxed text-center space-y-1">
        <span class="font-bold text-neutral-600 block uppercase tracking-wider">● CLARIMENTO SOURCING PROMISE</span>
        우리는 오직 생두 평가 점수 86점 이상의 싱글 오리진만을 선별하여 직접 거래 및 공정 무역 기준을 뛰어넘는 상생 무역으로 수입하고 있습니다.
      </div>

    </div>

  </div>

</div>

<script>
  // Sub state variables
  let profile = 'filter';
  let bags = 2;
  let frequency = '4weeks';
  let grind = 'Whole Bean';
  let step = 1;
  let activeSub = null;

  document.addEventListener('DOMContentLoaded', function() {
    // Load existing subscription from localStorage
    const saved = localStorage.getItem('clarimento_subscription');
    if (saved) {
      try {
        activeSub = JSON.parse(saved);
        showDashboard(activeSub);
      } catch (e) {
        activeSub = null;
      }
    }
    updateSummary();
  });

  function calculatePrice(bagCount) {
    if (bagCount === 1) return 22.00;
    if (bagCount === 2) return 40.00;
    if (bagCount === 3) return 58.00;
    return 74.00;
  }

  function getProfileLabel(p) {
    if (p === 'filter') return '필터 싱글오리진 (Filter Single Origin)';
    if (p === 'espresso') return '하우스 에스프레소 (House Espresso)';
    return '디카페인 셀렉션 (Decaf Selection)';
  }

  function selectSubProfile(p) {
    profile = p;
    document.querySelectorAll('.sub-profile-card').forEach(card => {
      card.className = "sub-profile-card p-5 border transition-all cursor-pointer relative bg-white border-neutral-200 hover:border-neutral-400";
      card.querySelector('.profile-accent-bar').classList.add('hidden');
    });

    const activeCard = document.getElementById('profile-card-' + p);
    activeCard.className = "sub-profile-card p-5 border transition-all cursor-pointer relative bg-neutral-950/2 border-neutral-900";
    activeCard.querySelector('.profile-accent-bar').classList.remove('hidden');

    updateSummary();
  }

  function selectSubBags(b) {
    bags = b;
    document.querySelectorAll('.sub-bags-card').forEach(card => {
      card.className = "sub-bags-card p-4 border text-center transition-all cursor-pointer relative bg-white border-neutral-200 hover:border-neutral-400";
      card.querySelector('.bags-accent-bar').classList.add('hidden');
    });

    const activeCard = document.getElementById('bags-card-' + b);
    activeCard.className = "sub-bags-card p-4 border text-center transition-all cursor-pointer relative bg-neutral-950/2 border-neutral-900";
    activeCard.querySelector('.bags-accent-bar').classList.remove('hidden');

    updateSummary();
  }

  function selectSubFrequency(f) {
    frequency = f;
    document.querySelectorAll('.sub-freq-card').forEach(card => {
      card.className = "sub-freq-card p-4 border transition-all cursor-pointer relative text-left bg-white border-neutral-200 hover:border-neutral-400";
      card.querySelector('.freq-accent-bar').classList.add('hidden');
    });

    const activeCard = document.getElementById('freq-card-' + f);
    activeCard.className = "sub-freq-card p-4 border transition-all cursor-pointer relative text-left bg-neutral-950/2 border-neutral-900";
    activeCard.querySelector('.freq-accent-bar').classList.remove('hidden');

    updateSummary();
  }

  function selectSubGrind(g) {
    grind = g;
    document.querySelectorAll('.sub-grind-card').forEach(card => {
      card.className = "sub-grind-card p-3 border text-center transition-all cursor-pointer text-xs font-semibold bg-white text-neutral-500 border-neutral-200 hover:border-neutral-400";
    });

    const safeId = g.replace(' ', '');
    const activeCard = document.getElementById('grind-card-' + safeId);
    activeCard.className = "sub-grind-card p-3 border text-center transition-all cursor-pointer text-xs font-semibold bg-neutral-950/2 text-neutral-950 border-neutral-900";

    updateSummary();
  }

  function updateSummary() {
    const pLabel = profile === 'filter' ? '필터 싱글오리진' : profile === 'espresso' ? '하우스 에스프레소' : '스페셜티 디카페인';
    document.getElementById('summary-profile-label').innerText = pLabel;
    document.getElementById('summary-bags-label').innerText = bags + ' Bag (' + (bags * 250) + 'g)';
    
    const price = calculatePrice(bags);
    document.getElementById('summary-bags-price').innerText = '$' + price.toFixed(2);
    document.getElementById('summary-breakdown-base').innerText = '$' + (bags * 22).toFixed(2);
    document.getElementById('summary-breakdown-discount').innerText = '-$' + ((bags * 22) - price).toFixed(2);
    document.getElementById('summary-total-price').innerText = '$' + price.toFixed(2);

    document.getElementById('summary-freq-label').innerText = frequency === '2weeks' ? '매 2주 마다' : '매 4주 마다';
    document.getElementById('summary-grind-label').innerText = grind;
  }

  function setStep(s) {
    step = s;
    if (s === 1) {
      document.getElementById('step-2-form').classList.add('hidden');
      document.getElementById('step-1-container').classList.remove('hidden');
      document.getElementById('summary-next-step-btn').classList.remove('hidden');
    } else {
      document.getElementById('step-1-container').classList.add('hidden');
      document.getElementById('step-2-form').classList.remove('hidden');
      document.getElementById('summary-next-step-btn').classList.add('hidden');
    }
  }

  function submitSubscription(e) {
    e.preventDefault();
    const name = document.getElementById('sub-recipient-name-input').value;
    const phone = document.getElementById('sub-recipient-phone-input').value;
    const address = document.getElementById('sub-recipient-address-input').value;
    const card = document.getElementById('sub-card-number-input').value;

    const subId = 'SUB-' + Math.floor(Math.random() * 90000 + 10000);
    const nextMon = new Date();
    nextMon.setDate(nextMon.getDate() + ((1 + 7 - nextMon.getDay()) % 7 || 7));
    const nextMonStr = nextMon.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' });

    const newSub = {
      id: subId,
      profile: profile,
      bags: bags,
      frequency: frequency,
      grind: grind,
      recipientName: name,
      phone: phone,
      address: address,
      paymentCard: '•••• •••• •••• ' + card.slice(-4),
      status: 'active',
      nextShipmentDate: nextMonStr
    };

    localStorage.setItem('clarimento_subscription', JSON.stringify(newSub));
    activeSub = newSub;
    showDashboard(newSub);
  }

  function showDashboard(sub) {
    document.getElementById('dash-id').innerText = 'ID: ' + sub.id;
    document.getElementById('dash-profile-title').innerText = getProfileLabel(sub.profile);
    document.getElementById('dash-price').innerText = '$' + calculatePrice(sub.bags).toFixed(2);
    document.getElementById('dash-config-desc').innerText = sub.bags + ' Bags (' + (sub.bags * 250) + 'g) / ' + sub.grind;
    document.getElementById('dash-frequency-desc').innerText = sub.frequency === '2weeks' ? '매 2주 마다 자동 배송' : '매 4주 마다 자동 배송';
    
    const badge = document.getElementById('dash-status-badge');
    const toggleBtn = document.getElementById('toggle-sub-btn');
    if (sub.status === 'active') {
      badge.innerText = '● 구독 활성';
      badge.className = "text-[10px] font-bold uppercase tracking-widest px-2.5 py-0.5 rounded-sm bg-emerald-50 text-emerald-700 border border-emerald-100";
      toggleBtn.innerText = "구독 일시정지";
      document.getElementById('dash-next-date').innerText = sub.nextShipmentDate;
    } else {
      badge.innerText = '○ 일시 정지됨';
      badge.className = "text-[10px] font-bold uppercase tracking-widest px-2.5 py-0.5 rounded-sm bg-amber-50 text-amber-700 border border-amber-100";
      toggleBtn.innerText = "구독 다시 시작";
      document.getElementById('dash-next-date').innerText = '구독 일시정지 중';
    }

    document.getElementById('dash-recipient-name').innerText = sub.recipientName;
    document.getElementById('dash-recipient-phone').innerText = '(' + sub.phone + ')';
    document.getElementById('dash-recipient-address').innerText = sub.address;
    document.getElementById('dash-payment-card').innerText = sub.paymentCard;

    document.getElementById('sub-configurator-view').classList.add('hidden');
    document.getElementById('sub-dashboard-view').classList.remove('hidden');
  }

  function toggleSubStatus() {
    if (!activeSub) return;
    activeSub.status = activeSub.status === 'active' ? 'paused' : 'active';
    localStorage.setItem('clarimento_subscription', JSON.stringify(activeSub));
    showDashboard(activeSub);
  }

  function triggerShipNow() {
    alert('이번 주 정기 배송이 즉시 준비 중으로 변경되었습니다. 화요일 아침에 안전하게 발송됩니다!');
  }

  function cancelSubscription() {
    if (confirm('정말로 정기 구독을 취소하시겠습니까? 언제든지 다시 가입하실 수 있습니다.')) {
      localStorage.removeItem('clarimento_subscription');
      activeSub = null;
      setStep(1);
      document.getElementById('step-2-form').reset();
      document.getElementById('sub-dashboard-view').classList.add('hidden');
      document.getElementById('sub-configurator-view').classList.remove('hidden');
    }
  }
</script>

{% schema %}
{
  "name": "Main Subscriptions Page",
  "settings": []
}
{% endschema %}
